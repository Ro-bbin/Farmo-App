<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#FFFFFF">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Filter Products"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#00473B"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Status"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <RadioGroup
        android:id="@+id/rgFilter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">
        <RadioButton android:id="@+id/rbAll" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="All" android:checked="true"/>
        <RadioButton android:id="@+id/rbAvailable" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Available"/>
        <RadioButton android:id="@+id/rbNotAvailable" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Not Available"/>
        <RadioButton android:id="@+id/rbExpired" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Expired"/>
        <RadioButton android:id="@+id/rbDeleted" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Deleted"/>
    </RadioGroup>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE"
        android:layout_marginVertical="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Date Range (Max 125 days)"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvDateFrom"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:padding="12dp"
            android:background="@drawable/edittext_border"
            android:hint="From: dd-mm-yyyy"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/tvDateTo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:padding="12dp"
            android:background="@drawable/edittext_border"
            android:hint="To: dd-mm-yyyy"
            android:layout_marginStart="10dp"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <Button
        android:id="@+id/btnApplyFilter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Apply Filter"
        android:backgroundTint="#00473B"
        android:textColor="#FFFFFF"/>

</LinearLayout>
